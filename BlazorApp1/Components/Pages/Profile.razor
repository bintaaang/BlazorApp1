@page "/profile"
@attribute [Authorize(Policy = "view_profile")]
@inject IUserService UserService
@inject AuthenticationStateProvider AuthStateProvider

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="h3 mb-0">My Profile</h1>
        </div>
    </div>

    <AuthorizeView>
        <Authorized>
            @if (currentUser != null)
            {
                <div class="row">
                    <div class="col-lg-8">
                        <div class="card">
                            <div class="card-header bg-light">
                                <h5 class="mb-0">Personal Information</h5>
                            </div>
                            <div class="card-body">
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">Full Name</label>
                                        <p>@currentUser.FullName</p>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">Username</label>
                                        <p>@currentUser.Username</p>
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">Email</label>
                                        <p>@currentUser.Email</p>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold">User ID</label>
                                        <p>@currentUser.Id</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card mt-3">
                            <div class="card-header bg-light">
                                <h5 class="mb-0">Roles & Permissions</h5>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Assigned Roles</label>
                                    <div>
                                        @if (currentUser.Roles.Count > 0)
                                        {
                                            @foreach (var role in currentUser.Roles)
                                            {
                                                <span class="badge bg-primary me-2">@role</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">No roles assigned</span>
                                        }
                                    </div>
                                </div>

                                <div>
                                    <label class="form-label fw-bold">Permissions</label>
                                    <div>
                                        @if (currentUser.Permissions.Count > 0)
                                        {
                                            <ul class="list-unstyled">
                                                @foreach (var permission in currentUser.Permissions)
                                                {
                                                    <li class="mb-2">
                                                        <span class="badge bg-success">✓</span> @permission
                                                    </li>
                                                }
                                            </ul>
                                        }
                                        else
                                        {
                                            <span class="text-muted">No permissions assigned</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="card">
                            <div class="card-header bg-light">
                                <h5 class="mb-0">Quick Info</h5>
                            </div>
                            <div class="card-body">
                                <p class="mb-2">
                                    <strong>Total Roles:</strong> @currentUser.Roles.Count
                                </p>
                                <p class="mb-2">
                                    <strong>Total Permissions:</strong> @currentUser.Permissions.Count
                                </p>
                                <hr />
                                <p class="text-muted small">
                                    This is your profile page. All information is retrieved from the database 
                                    based on your user ID and assigned roles/permissions.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </Authorized>
        <NotAuthorized>
            <div class="alert alert-warning">
                You do not have permission to access this page.
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>

@code {
    private UserDto? currentUser;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var userIdClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (userIdClaim != null && int.TryParse(userIdClaim.Value, out var userId))
            {
                currentUser = await UserService.GetUserByIdAsync(userId);
            }
        }
    }
}
