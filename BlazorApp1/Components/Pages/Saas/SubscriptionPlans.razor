@page "/saas/plans"
@attribute [Authorize(Policy = "manage_subscription_plans")]
@inject ISaasManagementService Service
@inject AuthenticationStateProvider AuthStateProvider
@inject MessageService MessageService

<div class="container-fluid">
    <div class="mb-4">
        <h1 class="h2 fw-bold mb-1">Subscription Plans</h1>
        <p class="text-secondary mb-0">Kelola paket, limit pemakaian, dan harga berlangganan bulanan.</p>
    </div>

    @if (showTable)
    {
        <div class="card border-light">
            <div class="card-body">
                <Table TItem="SubscriptionPlan" Items="plans" IsStriped="true" IsBordered="true" IsPagination="true" PageItemsSource="@PageItemsSource" ShowToolbar="true" ShowDefaultButtons="false">
                    <TableColumns>
                        <TableColumn @bind-Field="@context.Name" Text="Plan" Sortable="true" Filterable="true" />
                        <TableColumn @bind-Field="@context.MonthlyPrice" Text="Monthly Price" Sortable="true">
                            <Template Context="x">@FormatCurrency(x.Row.MonthlyPrice)</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.UserLimit" Text="Users" Sortable="true" />
                        <TableColumn @bind-Field="@context.CustomerLimit" Text="Customers" Sortable="true" />
                        <TableColumn @bind-Field="@context.InvoiceLimit" Text="Invoices" Sortable="true" />
                        <TableColumn @bind-Field="@context.IsActive" Text="Active" Sortable="true" />
                        <TableColumn @bind-Field="@context.Id" Text="" Width="90" Filterable="false" Sortable="false">
                            <Template Context="x">
                                <Button Color="Color.None" Icon="fa-solid fa-pen" Size="Size.ExtraSmall" OnClick="() => EditAsync(x.Value)" />
                                <PopConfirmButton Color="Color.None" Icon="fa-solid fa-trash" Size="Size.ExtraSmall" Content="Hapus plan ini?" OnConfirm="() => DeleteAsync(x.Value)" />
                            </Template>
                        </TableColumn>
                    </TableColumns>
                    <TableExtensionToolbarTemplate>
                        <Button Text="Add Plan" ButtonStyle="ButtonStyle.None" Icon="bi bi-plus-lg" Color="Color.Link" OnClick="AddNew" />
                    </TableExtensionToolbarTemplate>
                </Table>
            </div>
        </div>
    }
    else
    {
        <EditForm Model="plan" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="card border-light">
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Plan Name</label>
                            <InputText class="form-control" @bind-Value="plan.Name" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Monthly Price</label>
                            <InputNumber class="form-control" @bind-Value="plan.MonthlyPrice" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <InputText class="form-control" @bind-Value="plan.Description" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">User Limit</label>
                            <InputNumber class="form-control" @bind-Value="plan.UserLimit" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Customer Limit</label>
                            <InputNumber class="form-control" @bind-Value="plan.CustomerLimit" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Invoice Limit</label>
                            <InputNumber class="form-control" @bind-Value="plan.InvoiceLimit" />
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <InputCheckbox class="form-check-input" @bind-Value="plan.IsActive" />
                                <label class="form-check-label">Active plan</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <Button ButtonType="ButtonType.Submit" Color="Color.Primary" Icon="fa-solid fa-floppy-disk" Text="Save" />
                <Button ButtonType="ButtonType.Button" Color="Color.Secondary" Icon="fa-solid fa-xmark" Text="Cancel" OnClick="Cancel" />
            </div>
        </EditForm>
    }
</div>

@code {
    private List<SubscriptionPlan> plans = [];
    private SubscriptionPlan plan = new();
    private bool showTable = true;
    private string currentUser = "system";

    private static IEnumerable<int> PageItemsSource => new int[] { 10, 20, 50 };

    protected override async Task OnInitializedAsync()
    {
        currentUser = (await AuthStateProvider.GetAuthenticationStateAsync()).User.Identity?.Name ?? "system";
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        plans = await Service.GetSubscriptionPlansAsync();
        showTable = true;
    }

    private void AddNew()
    {
        plan = new SubscriptionPlan { IsActive = true, CreatedBy = currentUser };
        showTable = false;
    }

    private async Task EditAsync(int id)
    {
        plan = await Service.GetSubscriptionPlanByIdAsync(id) ?? new SubscriptionPlan();
        showTable = false;
    }

    private async Task SaveAsync()
    {
        plan.UpdatedBy = currentUser;
        var result = await Service.SaveSubscriptionPlanAsync(plan);
        await HandleResultAsync(result);
    }

    private async Task DeleteAsync(int id)
    {
        var result = await Service.DeleteSubscriptionPlanAsync(id);
        await HandleResultAsync(result);
    }

    private void Cancel() => showTable = true;

    private async Task HandleResultAsync(string result)
    {
        if (result == "ok")
        {
            await RefreshAsync();
            return;
        }

        await MessageService.Show(new MessageOption { Color = Color.Danger, Content = result, Icon = "fa-solid fa-circle-info" });
    }

    private static string FormatCurrency(decimal value)
        => string.Create(System.Globalization.CultureInfo.GetCultureInfo("id-ID"), $"Rp {value:N0}");
}
