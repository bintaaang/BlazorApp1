@page "/operations/service-items"
@attribute [Authorize(Policy = "manage_service_items")]
@inject ISaasManagementService Service
@inject AuthenticationStateProvider AuthStateProvider
@inject MessageService MessageService

<div class="container-fluid">
    <div class="mb-4">
        <h1 class="h2 fw-bold mb-1">Service Catalog</h1>
        <p class="text-secondary mb-0">Kelola layanan yang dijual tenant sebagai dasar quotation, order, dan invoice.</p>
    </div>

    @if (showTable)
    {
        <div class="card border-light">
            <div class="card-body">
                <Table TItem="ServiceItem" Items="items" IsStriped="true" IsBordered="true" IsPagination="true" PageItemsSource="@PageItemsSource" ShowToolbar="true" ShowDefaultButtons="false">
                    <TableColumns>
                        <TableColumn @bind-Field="@context.Name" Text="Service" Sortable="true" Filterable="true" />
                        <TableColumn @bind-Field="@context.TenantId" Text="Tenant">
                            <Template Context="x">@(x.Row.Tenant?.BusinessName ?? "-")</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.Category" Text="Category" Sortable="true" />
                        <TableColumn @bind-Field="@context.UnitPrice" Text="Unit Price" Sortable="true">
                            <Template Context="x">@FormatCurrency(x.Row.UnitPrice)</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.IsActive" Text="Active" Sortable="true" />
                        <TableColumn @bind-Field="@context.Id" Text="" Width="90" Filterable="false" Sortable="false">
                            <Template Context="x">
                                <Button Color="Color.None" Icon="fa-solid fa-pen" Size="Size.ExtraSmall" OnClick="() => EditAsync(x.Value)" />
                                <PopConfirmButton Color="Color.None" Icon="fa-solid fa-trash" Size="Size.ExtraSmall" Content="Hapus service item ini?" OnConfirm="() => DeleteAsync(x.Value)" />
                            </Template>
                        </TableColumn>
                    </TableColumns>
                    <TableExtensionToolbarTemplate>
                        <Button Text="Add Service" ButtonStyle="ButtonStyle.None" Icon="bi bi-plus-lg" Color="Color.Link" OnClick="AddNew" />
                    </TableExtensionToolbarTemplate>
                </Table>
            </div>
        </div>
    }
    else
    {
        <EditForm Model="item" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="card border-light">
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Tenant</label>
                            <InputSelect class="form-select" @bind-Value="item.TenantId">
                                <option value="0">Select tenant</option>
                                @foreach (var tenant in tenants)
                                {
                                    <option value="@tenant.Id">@tenant.BusinessName</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Service Name</label>
                            <InputText class="form-control" @bind-Value="item.Name" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Category</label>
                            <InputText class="form-control" @bind-Value="item.Category" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Unit Price</label>
                            <InputNumber class="form-control" @bind-Value="item.UnitPrice" />
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <InputCheckbox class="form-check-input" @bind-Value="item.IsActive" />
                                <label class="form-check-label">Active service</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <Button ButtonType="ButtonType.Submit" Color="Color.Primary" Icon="fa-solid fa-floppy-disk" Text="Save" />
                <Button ButtonType="ButtonType.Button" Color="Color.Secondary" Icon="fa-solid fa-xmark" Text="Cancel" OnClick="Cancel" />
            </div>
        </EditForm>
    }
</div>

@code {
    private List<ServiceItem> items = [];
    private List<Tenant> tenants = [];
    private ServiceItem item = new();
    private bool showTable = true;
    private string currentUser = "system";

    private static IEnumerable<int> PageItemsSource => new int[] { 10, 20, 50 };

    protected override async Task OnInitializedAsync()
    {
        currentUser = (await AuthStateProvider.GetAuthenticationStateAsync()).User.Identity?.Name ?? "system";
        tenants = await Service.GetTenantsAsync();
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        items = await Service.GetServiceItemsAsync();
        showTable = true;
    }

    private void AddNew()
    {
        item = new ServiceItem { TenantId = tenants.FirstOrDefault()?.Id ?? 0, IsActive = true, CreatedBy = currentUser };
        showTable = false;
    }

    private async Task EditAsync(int id)
    {
        item = await Service.GetServiceItemByIdAsync(id) ?? new ServiceItem();
        showTable = false;
    }

    private async Task SaveAsync()
    {
        item.UpdatedBy = currentUser;
        var result = await Service.SaveServiceItemAsync(item);
        await HandleResultAsync(result);
    }

    private async Task DeleteAsync(int id)
    {
        var result = await Service.DeleteServiceItemAsync(id);
        await HandleResultAsync(result);
    }

    private void Cancel() => showTable = true;

    private async Task HandleResultAsync(string result)
    {
        if (result == "ok")
        {
            await RefreshAsync();
            return;
        }

        await MessageService.Show(new MessageOption { Color = Color.Danger, Content = result, Icon = "fa-solid fa-circle-info" });
    }

    private static string FormatCurrency(decimal value)
        => string.Create(System.Globalization.CultureInfo.GetCultureInfo("id-ID"), $"Rp {value:N0}");
}