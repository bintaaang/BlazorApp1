@page "/operations/work-orders"
@attribute [Authorize(Policy = "view_work_orders")]
@inject ISaasManagementService Service
@inject AuthenticationStateProvider AuthStateProvider
@inject MessageService MessageService

<div class="container-fluid">
    <div class="mb-4">
        <h1 class="h2 fw-bold mb-1">Work Orders</h1>
        <p class="text-secondary mb-0">Kelola job ticket operasional dari customer hingga siap ditagihkan.</p>
    </div>

    @if (showTable)
    {
        <div class="card border-light">
            <div class="card-body">
                <Table TItem="WorkOrder" Items="workOrders" IsStriped="true" IsBordered="true" IsPagination="true" PageItemsSource="@PageItemsSource" ShowToolbar="true" ShowDefaultButtons="false">
                    <TableColumns>
                        <TableColumn @bind-Field="@context.OrderNumber" Text="Order Number" Sortable="true" Filterable="true" />
                        <TableColumn @bind-Field="@context.Title" Text="Title" Sortable="true" />
                        <TableColumn @bind-Field="@context.CustomerDataId" Text="Customer">
                            <Template Context="x">@(x.Row.CustomerData?.CustomerName ?? "-")</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.TenantId" Text="Tenant">
                            <Template Context="x">@(x.Row.Tenant?.BusinessName ?? "-")</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.Status" Text="Status" Sortable="true" />
                        <TableColumn @bind-Field="@context.EstimatedAmount" Text="Estimated Amount" Sortable="true">
                            <Template Context="x">@FormatCurrency(x.Row.EstimatedAmount)</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.DueDate" Text="Due Date" Sortable="true" />
                        <TableColumn @bind-Field="@context.Id" Text="" Width="90" Filterable="false" Sortable="false">
                            <Template Context="x">
                                <Button Color="Color.None" Icon="fa-solid fa-pen" Size="Size.ExtraSmall" OnClick="() => EditAsync(x.Value)" />
                                <PopConfirmButton Color="Color.None" Icon="fa-solid fa-trash" Size="Size.ExtraSmall" Content="Hapus work order ini?" OnConfirm="() => DeleteAsync(x.Value)" />
                            </Template>
                        </TableColumn>
                    </TableColumns>
                    <TableExtensionToolbarTemplate>
                        <Button Text="Add Work Order" ButtonStyle="ButtonStyle.None" Icon="bi bi-plus-lg" Color="Color.Link" OnClick="AddNew" />
                    </TableExtensionToolbarTemplate>
                </Table>
            </div>
        </div>
    }
    else
    {
        <EditForm Model="workOrder" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="card border-light">
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Tenant</label>
                            <InputSelect class="form-select" @bind-Value="workOrder.TenantId">
                                <option value="0">Select tenant</option>
                                @foreach (var tenant in tenants)
                                {
                                    <option value="@tenant.Id">@tenant.BusinessName</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Customer</label>
                            <InputSelect class="form-select" @bind-Value="workOrder.CustomerDataId">
                                <option value="">No customer</option>
                                @foreach (var customer in customers)
                                {
                                    <option value="@customer.Id">@customer.CustomerName</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Status</label>
                            <InputSelect class="form-select" @bind-Value="workOrder.Status">
                                @foreach (var status in WorkOrderStatuses)
                                {
                                    <option value="@status">@status</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Order Number</label>
                            <InputText class="form-control" @bind-Value="workOrder.OrderNumber" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">Title</label>
                            <InputText class="form-control" @bind-Value="workOrder.Title" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <InputTextArea class="form-control" @bind-Value="workOrder.Description" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Order Date</label>
                            <InputDate class="form-control" @bind-Value="workOrder.OrderDate" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Due Date</label>
                            <InputDate class="form-control" @bind-Value="workOrder.DueDate" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Estimated Amount</label>
                            <InputNumber class="form-control" @bind-Value="workOrder.EstimatedAmount" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <Button ButtonType="ButtonType.Submit" Color="Color.Primary" Icon="fa-solid fa-floppy-disk" Text="Save" />
                <Button ButtonType="ButtonType.Button" Color="Color.Secondary" Icon="fa-solid fa-xmark" Text="Cancel" OnClick="Cancel" />
            </div>
        </EditForm>
    }
</div>

@code {
    private static readonly string[] WorkOrderStatuses = ["New", "In Progress", "Waiting", "Completed", "Canceled"];
    private List<WorkOrder> workOrders = [];
    private List<Tenant> tenants = [];
    private List<CustomerData> customers = [];
    private WorkOrder workOrder = new();
    private bool showTable = true;
    private string currentUser = "system";

    private static IEnumerable<int> PageItemsSource => new int[] { 10, 20, 50 };

    protected override async Task OnInitializedAsync()
    {
        currentUser = (await AuthStateProvider.GetAuthenticationStateAsync()).User.Identity?.Name ?? "system";
        tenants = await Service.GetTenantsAsync();
        customers = await Service.GetCustomersAsync();
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        workOrders = await Service.GetWorkOrdersAsync();
        showTable = true;
    }

    private void AddNew()
    {
        workOrder = new WorkOrder
        {
            TenantId = tenants.FirstOrDefault()?.Id ?? 0,
            CustomerDataId = customers.FirstOrDefault()?.Id,
            OrderNumber = $"WO-{DateTime.UtcNow:yyyyMMddHHmm}",
            OrderDate = DateTime.UtcNow,
            DueDate = DateTime.UtcNow.AddDays(7),
            Status = "New",
            CreatedBy = currentUser
        };
        showTable = false;
    }

    private async Task EditAsync(int id)
    {
        workOrder = await Service.GetWorkOrderByIdAsync(id) ?? new WorkOrder();
        showTable = false;
    }

    private async Task SaveAsync()
    {
        workOrder.UpdatedBy = currentUser;
        var result = await Service.SaveWorkOrderAsync(workOrder);
        await HandleResultAsync(result);
    }

    private async Task DeleteAsync(int id)
    {
        var result = await Service.DeleteWorkOrderAsync(id);
        await HandleResultAsync(result);
    }

    private void Cancel() => showTable = true;

    private async Task HandleResultAsync(string result)
    {
        if (result == "ok")
        {
            await RefreshAsync();
            return;
        }

        await MessageService.Show(new MessageOption { Color = Color.Danger, Content = result, Icon = "fa-solid fa-circle-info" });
    }

    private static string FormatCurrency(decimal value)
        => string.Create(System.Globalization.CultureInfo.GetCultureInfo("id-ID"), $"Rp {value:N0}");
}