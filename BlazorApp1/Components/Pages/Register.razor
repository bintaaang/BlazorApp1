@page "/register"
@layout EmptyLayout
@inject IAuthService AuthService
@inject NavigationManager Navigation

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-5 col-lg-6 col-md-8">
            <Card HeaderText="Register" class="bb-auth-card">
                <BodyTemplate>
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger mb-4" role="alert">
                            @errorMessage
                        </div>
                    }

                    @if (registrationSuccess)
                    {
                        <div class="alert alert-success mb-4" role="alert">
                            <strong>Berhasil!</strong> Silakan login dengan akun baru Anda.
                        </div>
                    }

                    <ValidateForm Model="@registerModel" OnValidSubmit="@HandleRegister">
                        <BootstrapBlazorDataAnnotationsValidator />
                        <ValidationSummary />

                        <BootstrapInput @bind-Value="@registerModel.FullName"
                                        DisplayText="Nama Lengkap"
                                        ShowLabel="true"
                                        placeholder="Masukkan nama lengkap" />

                        <BootstrapInput @bind-Value="@registerModel.Username"
                                        DisplayText="Username"
                                        ShowLabel="true"
                                        placeholder="Masukkan username" />

                        <BootstrapInput @bind-Value="@registerModel.Email"
                                        DisplayText="Email"
                                        ShowLabel="true"
                                        type="email"
                                        placeholder="Masukkan email" />

                        <BootstrapPassword @bind-Value="@registerModel.Password"
                                           DisplayText="Password"
                                           ShowLabel="true"
                                           placeholder="Masukkan password" />

                        <BootstrapPassword @bind-Value="@registerModel.ConfirmPassword"
                                           DisplayText="Konfirmasi Password"
                                           ShowLabel="true"
                                           placeholder="Konfirmasi password" />

                        <Button Text="Register"
                                ButtonType="ButtonType.Submit"
                                Color="Color.Primary"
                                class="w-100 mt-3" />
                    </ValidateForm>

                    <div class="bb-auth-card__footer">
                        <p class="mb-0">Sudah punya akun? <a href="/login">Login di sini</a></p>
                    </div>
                </BodyTemplate>
            </Card>
        </div>
    </div>
</div>

@code {
    private RegisterRequest registerModel = new();
    private string? errorMessage;
    private bool registrationSuccess;

    private async Task HandleRegister(EditContext _)
    {
        errorMessage = null;
        registrationSuccess = false;

        try
        {
            var (success, message) = await AuthService.RegisterAsync(registerModel);

            if (success)
            {
                registrationSuccess = true;
                registerModel = new();
                await Task.Delay(1500);
                Navigation.NavigateTo("/login");
            }
            else
            {
                errorMessage = message;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
    }
}
