@page "/admin/users"
@attribute [Authorize(Policy = "manage_users")]
@inject IUserService UserService
@using System.ComponentModel.DataAnnotations

<div class="container-fluid">
    <h4 class="text-primary">User Management</h4>

    <AuthorizeView>
        <Authorized>
            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger" role="alert">@errorMessage</div>
            }

            @if (!string.IsNullOrWhiteSpace(actionMessage))
            {
                <div class="alert alert-info" role="alert">@actionMessage</div>
            }

            @if (!isFormVisible)
            {
                <div class="card border-light">
                    <div class="card-body">
                        @if (rows == null)
                        {
                            <p>Loading ...</p>
                        }
                        else
                        {
                            <Table @ref="tableRef"
                                   @key="tableVersion"
                                   TItem="UserDto"
                                   class="bb-user-table"
                                   IsStriped="true"
                                   IsBordered="true"
                                   IsTracking="true"
                                   ShowSkeleton="false"
                                   OnQueryAsync="@OnQueryAsync"
                                   IsPagination="true"
                                   PageItemsSource="@PageItemsSource"
                                   ShowRefresh="false"
                                   ShowToolbar="true"
                                   ShowDefaultButtons="false">
                                <TableToolbarBeforeTemplate>
                                </TableToolbarBeforeTemplate>
                                <TableColumns Context="tableColumnContext">
                                    <TableColumn @bind-Field="@tableColumnContext.Id" Text="ID" Sortable="true" Filterable="true" />
                                    <TableColumn @bind-Field="@tableColumnContext.Username" Text="Username" Sortable="true" Filterable="true" />
                                    <TableColumn @bind-Field="@tableColumnContext.FullName" Text="Full Name" Sortable="true" Filterable="true" />
                                    <TableColumn @bind-Field="@tableColumnContext.Email" Text="Email" Sortable="true" Filterable="true" />
                                    <TableColumn @bind-Field="@tableColumnContext.StatusText" Text="Status" Sortable="true" Filterable="true" />
                                    <TableColumn @bind-Field="@tableColumnContext.RolesText" Text="Role" Sortable="true" Filterable="true" />
                                    <TableColumn @bind-Field="@tableColumnContext.PermissionCount" Text="Permissions" Sortable="true" Filterable="true" />
                                    <TableColumn @bind-Field="@tableColumnContext.Id" Text="" Width="70" Filterable="false" Sortable="false">
                                        <Template Context="x">
                                            <PopConfirmButton Color="Color.None"
                                                              Icon="fa-solid fa-trash"
                                                              IsAsync="true"
                                                              Size="Size.ExtraSmall"
                                                              Content="Are you sure to remove this item?"
                                                              OnConfirm="() => Delete(x.Value)" />
                                            <span class="w-50"></span>
                                            <Button Color="Color.None"
                                                    Icon="fa-solid fa-pen"
                                                    Size="Size.ExtraSmall"
                                                    OnClick="() => Edit(x.Value)" />
                                        </Template>
                                    </TableColumn>
                                </TableColumns>
                                <TableExtensionToolbarTemplate>
                                    <Button Text="Add"
                                            ButtonStyle="ButtonStyle.None"
                                            Icon="bi bi-plus-lg"
                                            Color="Color.Link"
                                            OnClick="AddNew" />
                                </TableExtensionToolbarTemplate>
                            </Table>
                        }
                    </div>
                </div>
            }
            else
            {
                <section class="bb-user-form">
                    <ValidateForm Model="@formModel" OnValidSubmit="@SaveAsync">
                        <BootstrapBlazorDataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <BootstrapInput @bind-Value="@formModel.FullName" ShowLabel="true" />
                            </div>
                            <div class="col-12 col-md-6">
                                <BootstrapInput @bind-Value="@formModel.Username" ShowLabel="true" />
                            </div>
                            <div class="col-12 col-md-6">
                                <BootstrapInput @bind-Value="@formModel.Email" ShowLabel="true" type="email" />
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">Role</label>
                                <Select TValue="string"
                                        Items="@roleOptions"
                                        @bind-Value="@formModel.RoleName"
                                        ShowLabel="false"
                                        PlaceHolder="Pilih role"
                                        ShowSearch="true" />
                            </div>
                            <div class="col-12 col-md-6">
                                <BootstrapPassword @bind-Value="@formModel.Password"
                                                   ShowLabel="true"
                                                   PlaceHolder="@(isEditMode ? "Kosongkan jika tidak diubah" : "Masukkan password")" />
                            </div>
                            <div class="col-12 col-md-6">
                                <BootstrapPassword @bind-Value="@formModel.ConfirmPassword"
                                                   ShowLabel="true"
                                                   PlaceHolder="@(isEditMode ? "Ulangi password baru bila diubah" : "Konfirmasi password")" />
                            </div>
                            <div class="col-12 d-flex gap-2">
                                <Button ButtonType="@ButtonType.Submit"
                                        Color="Color.Primary"
                                        Icon="bi bi-floppy"
                                        Text="Save" />
                                <Button ButtonType="@ButtonType.Button"
                                        Color="Color.Secondary"
                                        Icon="bi bi-x-lg"
                                        Text="Cancel"
                                        OnClick="Cancel" />
                            </div>
                        </div>
                    </ValidateForm>
                </section>
            }
        </Authorized>
        <NotAuthorized>
            <div class="alert alert-warning">You do not have permission to access this page.</div>
        </NotAuthorized>
    </AuthorizeView>
</div>

@code {
    private List<UserDto>? rows;
    private Table<UserDto>? tableRef;
    private UserDto formModel = NewFormModel();
    private List<SelectedItem> roleOptions = [];
    private string? errorMessage;
    private string? actionMessage;
    private int? editingUserId;
    private int tableVersion;
    private bool isFormVisible;

    private bool isEditMode => editingUserId.HasValue;

    private static IEnumerable<int> PageItemsSource => [10, 20, 50];

    protected override async Task OnInitializedAsync()
    {
        roleOptions = (await UserService.GetRoleNamesAsync())
            .Select((roleName, index) => new SelectedItem(roleName, roleName) { Active = index == 0 })
            .ToList();

        SetDefaultRole();
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        errorMessage = null;

        try
        {
            rows = await UserService.GetAllUsersAsync();
        }
        catch (Exception ex)
        {
            rows = [];
            errorMessage = $"Gagal memuat user: {ex.Message}";
        }
    }

    private async Task<QueryData<UserDto>> OnQueryAsync(QueryPageOptions options)
    {
        await EnsureUsersLoadedAsync();
        return UserTableQuery.Build(rows ?? [], options);
    }

    private void AddNew()
    {
        ResetMessages();
        editingUserId = null;
        formModel = NewFormModel();
        SetDefaultRole();
        isFormVisible = true;
    }

    private async Task Edit(int id)
    {
        ResetMessages();

        var user = await UserService.GetUserByIdAsync(id);
        if (user == null)
        {
            errorMessage = "Data user tidak ditemukan.";
            return;
        }

        editingUserId = id;
        formModel = new UserDto
        {
            Id = user.Id,
            Username = user.Username,
            Email = user.Email,
            FullName = user.FullName,
            RoleName = user.Roles.FirstOrDefault() ?? "User",
            IsActive = user.IsActive,
            IsEditMode = true
        };
        isFormVisible = true;
    }

    private async Task Delete(int id)
    {
        ResetMessages();

        var result = await UserService.DeleteUserAsync(id);
        if (!result.Success)
        {
            errorMessage = result.Message;
            return;
        }

        actionMessage = result.Message;
        await RefreshTableFromFirstPageAsync();
    }

    private async Task SaveAsync(EditContext _)
    {
        ResetMessages();

        if (!ValidateForm())
        {
            return;
        }

        var result = editingUserId.HasValue
            ? await UserService.UpdateUserAsync(editingUserId.Value, formModel)
            : await UserService.CreateUserAsync(formModel);

        if (!result.Success)
        {
            errorMessage = result.Message;
            return;
        }

        actionMessage = result.Message;
        isFormVisible = false;
        editingUserId = null;
        formModel = NewFormModel();
        await RefreshTableFromFirstPageAsync();
    }

    private void Cancel()
    {
        ResetMessages();
        editingUserId = null;
        formModel = NewFormModel();
        isFormVisible = false;
    }

    private void ResetMessages()
    {
        errorMessage = null;
        actionMessage = null;
    }

    private bool ValidateForm()
    {
        var validationResults = formModel.Validate(new ValidationContext(formModel)).ToList();
        errorMessage = validationResults.FirstOrDefault()?.ErrorMessage;
        return validationResults.Count == 0;
    }

    private async Task EnsureUsersLoadedAsync()
    {
        if (rows == null)
        {
            await LoadUsersAsync();
        }
    }

    private async Task RefreshTableFromFirstPageAsync()
    {
        await LoadUsersAsync();
        tableVersion++;

        if (tableRef != null)
        {
            await tableRef.QueryAsync(1);
        }
    }

    private void SetDefaultRole()
    {
        if (roleOptions.Count > 0 && string.IsNullOrWhiteSpace(formModel.RoleName))
        {
            formModel.RoleName = roleOptions[0].Value;
        }
    }

    private static UserDto NewFormModel() => new()
    {
        IsActive = true,
        RoleName = "User"
    };
}
