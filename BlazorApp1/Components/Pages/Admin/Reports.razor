@page "/admin/reports"
@attribute [Authorize(Policy = "view_reports")]

<div class="container-fluid">
    <div class="bb-page-header">
        <h1>Reports</h1>
        <p>Overview dashboard menggunakan card BootstrapBlazor dengan Bootstrap 5 styling.</p>
    </div>

    <AuthorizeView>
        <Authorized>
            <div class="row g-4">
                <div class="col-xl-3 col-md-6">
                    <Card HeaderText="Total Users" Color="Color.Primary">
                        <BodyTemplate>
                            <div class="bb-stat-card">
                                <div class="bb-stat-card__value">42</div>
                                <div class="bb-stat-card__meta">registered accounts</div>
                            </div>
                        </BodyTemplate>
                    </Card>
                </div>

                <div class="col-xl-3 col-md-6">
                    <Card HeaderText="Active Sessions" Color="Color.Success">
                        <BodyTemplate>
                            <div class="bb-stat-card">
                                <div class="bb-stat-card__value">8</div>
                                <div class="bb-stat-card__meta">live sessions</div>
                            </div>
                        </BodyTemplate>
                    </Card>
                </div>

                <div class="col-xl-3 col-md-6">
                    <Card HeaderText="Page Views" Color="Color.Warning">
                        <BodyTemplate>
                            <div class="bb-stat-card">
                                <div class="bb-stat-card__value">156</div>
                                <div class="bb-stat-card__meta">today</div>
                            </div>
                        </BodyTemplate>
                    </Card>
                </div>

                <div class="col-xl-3 col-md-6">
                    <Card HeaderText="Uptime" Color="Color.Info">
                        <BodyTemplate>
                            <div class="bb-stat-card">
                                <div class="bb-stat-card__value">98%</div>
                                <div class="bb-stat-card__meta">availability</div>
                            </div>
                        </BodyTemplate>
                    </Card>
                </div>
            </div>

            <div class="row g-4 mt-1">
                <div class="col-xl-6">
                    <Card HeaderText="User Activity">
                        <BodyTemplate>
                            <p class="text-secondary mb-0">Activity chart placeholder using BootstrapBlazor card shell.</p>
                        </BodyTemplate>
                    </Card>
                </div>

                <div class="col-xl-6">
                    <Card HeaderText="System Statistics">
                        <BodyTemplate>
                            <p class="text-secondary mb-0">System statistics placeholder using BootstrapBlazor card shell.</p>
                        </BodyTemplate>
                    </Card>
                </div>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="alert alert-warning">You do not have permission to access this page.</div>
        </NotAuthorized>
    </AuthorizeView>
</div>
