@page "/admin/reports"
@attribute [Authorize(Policy = "view_reports")]

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="h3 mb-0">Reports</h1>
        </div>
    </div>

    <AuthorizeView>
        <Authorized>
            <div class="row">
                <div class="col-lg-3 mb-3">
                    <div class="card">
                        <div class="card-body text-center">
                            <h2 class="h4 text-primary">42</h2>
                            <p class="text-muted mb-0">Total Users</p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3 mb-3">
                    <div class="card">
                        <div class="card-body text-center">
                            <h2 class="h4 text-success">8</h2>
                            <p class="text-muted mb-0">Active Sessions</p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3 mb-3">
                    <div class="card">
                        <div class="card-body text-center">
                            <h2 class="h4 text-warning">156</h2>
                            <p class="text-muted mb-0">Page Views</p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3 mb-3">
                    <div class="card">
                        <div class="card-body text-center">
                            <h2 class="h4 text-info">98%</h2>
                            <p class="text-muted mb-0">Uptime</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-lg-6 mb-3">
                    <div class="card">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">User Activity</h5>
                        </div>
                        <div class="card-body">
                            <p class="text-muted">Activity chart would be displayed here</p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6 mb-3">
                    <div class="card">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">System Statistics</h5>
                        </div>
                        <div class="card-body">
                            <p class="text-muted">System stats would be displayed here</p>
                        </div>
                    </div>
                </div>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="alert alert-warning">
                You do not have permission to access this page.
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>
