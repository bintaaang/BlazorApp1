@page "/dashboard"
@attribute [Authorize(Policy = "view_dashboard")]
@inject IUserService UserService
@inject AuthenticationStateProvider AuthStateProvider

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="h3 mb-0">Dashboard</h1>
        </div>
    </div>

    <AuthorizeView>
        <Authorized>
            @if (currentUser != null)
            {
                <div class="row">
                    <div class="col-lg-4 mb-3">
                        <div class="card bg-primary text-white">
                            <div class="card-body">
                                <h6 class="card-title">User Information</h6>
                                <p class="mb-1"><strong>@currentUser.FullName</strong></p>
                                <p class="mb-0 small text-white-50">@currentUser.Email</p>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4 mb-3">
                        <div class="card bg-success text-white">
                            <div class="card-body">
                                <h6 class="card-title">Roles</h6>
                                <p class="mb-0">
                                    @if (currentUser.Roles.Count > 0)
                                    {
                                        @string.Join(", ", currentUser.Roles)
                                    }
                                    else
                                    {
                                        <span>No roles assigned</span>
                                    }
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4 mb-3">
                        <div class="card bg-info text-white">
                            <div class="card-body">
                                <h6 class="card-title">Permissions</h6>
                                <p class="mb-0 small">@currentUser.Permissions.Count permission(s)</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row mt-4">
                    <div class="col-lg-6">
                        <div class="card">
                            <div class="card-header bg-light">
                                <h5 class="mb-0">Your Permissions</h5>
                            </div>
                            <div class="card-body">
                                @if (currentUser.Permissions.Count > 0)
                                {
                                    <div class="list-group">
                                        @foreach (var permission in currentUser.Permissions)
                                        {
                                            <a class="list-group-item list-group-item-action">
                                                <span class="badge bg-success me-2">✓</span>@permission
                                            </a>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted">No permissions assigned</p>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-6">
                        <div class="card">
                            <div class="card-header bg-light">
                                <h5 class="mb-0">Welcome Message</h5>
                            </div>
                            <div class="card-body">
                                <p>Welcome to the Blazor RBAC Application, <strong>@currentUser.FullName</strong>!</p>
                                <p class="text-muted small">
                                    This application demonstrates role-based access control (RBAC) with dynamic permissions 
                                    from the database. All menus and page access are controlled based on your assigned permissions.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </Authorized>
        <NotAuthorized>
            <div class="alert alert-warning">
                You do not have permission to access this page.
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>

@code {
    private UserDto? currentUser;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var userIdClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (userIdClaim != null && int.TryParse(userIdClaim.Value, out var userId))
            {
                currentUser = await UserService.GetUserByIdAsync(userId);
            }
        }
    }
}
