@page "/dashboard"
@attribute [Authorize(Policy = "view_dashboard")]
@inject IUserService UserService
@inject AuthenticationStateProvider AuthStateProvider

<div class="container-fluid">
    <div class="bb-page-header">
        <h1>Dashboard</h1>
        <p>Ringkasan cepat akses, peran, dan permission user aktif.</p>
    </div>

    <AuthorizeView>
        <Authorized>
            @if (currentUser != null)
            {
                <div class="row g-4">
                    <div class="col-xl-4">
                        <Card HeaderText="User Information" Color="Color.Primary">
                            <BodyTemplate>
                                <div class="bb-stat-card">
                                    <div class="bb-stat-card__value">@currentUser.FullName</div>
                                    <div class="bb-stat-card__meta">@currentUser.Email</div>
                                </div>
                            </BodyTemplate>
                        </Card>
                    </div>

                    <div class="col-xl-4">
                        <Card HeaderText="Roles" Color="Color.Success">
                            <BodyTemplate>
                                <div class="bb-stat-card">
                                    <div class="bb-stat-card__value">@(currentUser.Roles.Count == 0 ? "0" : currentUser.Roles.Count.ToString())</div>
                                    <div class="bb-stat-card__meta">@(currentUser.Roles.Count == 0 ? "No roles assigned" : string.Join(", ", currentUser.Roles))</div>
                                </div>
                            </BodyTemplate>
                        </Card>
                    </div>

                    <div class="col-xl-4">
                        <Card HeaderText="Permissions" Color="Color.Info">
                            <BodyTemplate>
                                <div class="bb-stat-card">
                                    <div class="bb-stat-card__value">@currentUser.Permissions.Count</div>
                                    <div class="bb-stat-card__meta">permission(s) available</div>
                                </div>
                            </BodyTemplate>
                        </Card>
                    </div>
                </div>

                <div class="row g-4 mt-1">
                    <div class="col-xl-6">
                        <Card HeaderText="Your Permissions">
                            <BodyTemplate>
                                @if (currentUser.Permissions.Count > 0)
                                {
                                    <ul class="bb-list">
                                        @foreach (var permission in currentUser.Permissions)
                                        {
                                            <li>@permission</li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <span class="text-secondary">No permissions assigned.</span>
                                }
                            </BodyTemplate>
                        </Card>
                    </div>

                    <div class="col-xl-6">
                        <Card HeaderText="Welcome Message">
                            <BodyTemplate>
                                <p>Welcome to the Blazor RBAC Application, <strong>@currentUser.FullName</strong>.</p>
                                <p class="text-secondary mb-0">
                                    Semua akses halaman, menu, dan tindakan user saat ini dikontrol lewat role serta permission dari database.
                                </p>
                            </BodyTemplate>
                        </Card>
                    </div>
                </div>
            }
        </Authorized>
        <NotAuthorized>
            <div class="alert alert-warning">You do not have permission to access this page.</div>
        </NotAuthorized>
    </AuthorizeView>
</div>

@code {
    private UserDto? currentUser;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var userIdClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (userIdClaim != null && int.TryParse(userIdClaim.Value, out var userId))
            {
                currentUser = await UserService.GetUserByIdAsync(userId);
            }
        }
    }
}
