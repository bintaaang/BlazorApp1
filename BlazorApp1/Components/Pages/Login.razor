@page "/login"
@layout EmptyLayout
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.WebUtilities

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-4 col-lg-5 col-md-7">
            <Card HeaderText="Login" class="bb-auth-card">
                <BodyTemplate>
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger mb-4" role="alert">
                            @errorMessage
                        </div>
                    }

                    <form method="post" action="/auth/login">
                        <BootstrapInput @bind-Value="@loginModel.Username"
                                        name="Username"
                                        DisplayText="Username"
                                        ShowLabel="true"
                                        placeholder="Enter username" />

                        <BootstrapPassword @bind-Value="@loginModel.Password"
                                           name="Password"
                                           DisplayText="Password"
                                           ShowLabel="true"
                                           placeholder="Enter password" />

                        <Button Text="Login"
                                ButtonType="ButtonType.Submit"
                                Color="Color.Primary"
                                class="w-100 mt-3" />
                    </form>

                    <div class="bb-auth-card__footer">
                        <p class="mb-2">Belum punya akun? <a href="/register">Register di sini</a></p>
                        <div class="alert alert-info mb-0">
                            <strong>Demo Credentials</strong><br />
                            Admin: admin / admin123<br />
                            User: user / user123
                        </div>
                    </div>
                </BodyTemplate>
            </Card>
        </div>
    </div>
</div>

@code {
    private LoginRequest loginModel = new();
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo("/dashboard", replace: true);
            return;
        }

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("error", out var errorValues))
        {
            errorMessage = errorValues.ToString();
        }
    }
}
