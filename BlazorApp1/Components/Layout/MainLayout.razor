@inherits LayoutComponentBase

<div class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <span class="bi bi-app-indicator"></span> Blazor RBAC
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <AuthorizeView>
                            <Authorized>
                                <a class="nav-link" href="/profile">
                                    <span class="bi bi-person"></span> @context.User.FindFirst("FullName")?.Value
                                </a>
                            </Authorized>
                            <NotAuthorized>
                                <a class="nav-link" href="/login">Login</a>
                            </NotAuthorized>
                        </AuthorizeView>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container-fluid flex-grow-1">
        <div class="row h-100">
            <aside class="col-lg-2 bg-light border-end d-none d-lg-block">
                <nav class="navbar-nav pt-3">
                    <NavMenu />
                </nav>
            </aside>

            <main class="col-lg-10 p-4">
                @Body
            </main>
        </div>
    </div>

    <footer class="bg-dark text-white text-center py-3 mt-auto border-top border-secondary">
        <p class="mb-0">&copy; 2024 Blazor RBAC App. All rights reserved.</p>
    </footer>
</div>
